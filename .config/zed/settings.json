{
  /* Duplicated key auto-commented: "agent": {
    "always_allow_tool_actions": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4"
    }
  }, */
  "drag_and_drop_selection": {
    "enabled": true
  },
  "tasks": {
    "enabled": true
  },
  "lsp_document_colors": "inlay",
  "show_whitespaces": "selection",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "helix_mode": true,
  "buffer_font_weight": 500.0,
  "terminal": {
    "button": true,
    "font_family": "Maple Mono NF",
    "shell": "system"
  },
  "inline_code_actions": true,
  "relative_line_numbers": "enabled",
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true,
    "breakpoints": true,
    "runnables": true,
    "line_numbers": true
  },
  "vertical_scroll_margin": 3.0,
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "fixed",
    "active_line_width": 1,
    "line_width": 1,
    "enabled": true
  },
  "preferred_line_length": 80,
  "show_wrap_guides": true,
  "soft_wrap": "editor_width",
  "auto_indent": "syntax_aware",
  "hard_tabs": false,
  "tab_size": 2,
  "buffer_line_height": "comfortable",
  "zoomed_padding": false,
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "outline_panel": {
    "dock": "right",
    "auto_fold_dirs": true,
    "button": true
  },
  "tabs": {
    "git_status": true
  },
  "tab_bar": {
    "show": false
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_branch_status_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_menus": false
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true
  },
  "git_panel": {
    "dock": "right",
    "button": true,
    "sort_by_path": false
  },
  "disable_ai": true,
  "toolbar": {
    "agent_review": false,
    "selections_menu": true,
    "quick_actions": true,
    "breadcrumbs": true,
    "code_actions": true
  },
  "minimum_contrast_for_highlights": 40.0,
  "cursor_shape": "bar",
  "cursor_blink": true,
  "ui_font_weight": 500.0,
  "project_panel": {
    "hide_root": false,
    "dock": "right",
    "button": true,
    "default_width": 240
  },

  "context_servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--executablePath=/Applications/Helium.app/"]
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "button": true,
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "dock": "left",
    "default_width": 320
  },

  "collaboration_panel": {
    "button": false,
    "dock": "right",
    "default_width": 240
  },

  "notification_panel": {
    "button": false
  },
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false
    }
  },
  "buffer_font_family": "Berkeley Mono",
  "ui_font_family": "Berkeley Mono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": false,
  "icon_theme": "Colored Zed Icons Theme Dark",
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true
  },
  "theme": "poimandres",
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    }
  },
  "languages": {
    "Go": {
      "tab_size": 4,
      "hard_tabs": false
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,

        "source.organizeImports.biome": true
      }
    }
  }
}
